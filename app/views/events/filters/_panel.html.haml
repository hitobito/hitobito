- id = kind.to_s.pluralize
- caption ||= t("events/filters.#{kind}.title")
- open ||= true if filter.chain[kind.to_sym].present?

.accordion-item
  .accordion-header
    %a.accordion-button.p-2.bg-white.text-black{ href: "##{id}", data: { bs_toggle: :collapse } }
      = caption

  .accordion-collapse.collapse{ id: id, class: open ? "show" : nil }
    .accordion-body
      = yield
