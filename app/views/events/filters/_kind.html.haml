= f.fields_for(:course_kind) do |fields|
  .row.mb-2
    = fields.label(:id, ti('.kind'), class: "col-form-label col-md-3 col-xl-2")
    .col-md-9.mw-63ch
      - kinds = Event::Kind.list.without_deleted
      = fields.select(:id,
                      options_from_collection_for_select(kinds, :id, :to_s, Array(filter.chain.dig(:course_kind, :id))),
                      {},
                      class: "form-select form-select-sm w-100",
                      multiple: true,
                      data: { tom_select_no_results_value: t("global.no_list_entries"),
                              controller: "tom-select" })
