= entry_form(url: group_invoice_run_path(group),
             cancel_url: cancel_url,
             data: { group: group_path(group) }) do |f|

  = hidden_field_tag "ids", params[:ids]
  = hidden_field_tag "filter", params[:filter] ? params[:filter].to_json : nil

  - if entry.recipient_source
    = f.hidden_field :recipient_source_id
    = f.hidden_field :recipient_source_type

  .row
    .labeled.col-md-9.col-lg-8.col-xl-8.mw-63ch.offset-md-3.offset-xl-2
      .alert.alert-warning
        = t('.recipient_count_disclaimer')

  = f.fields_for :invoice, entry.invoice do |fi|
    = render "invoices/message_template", f: fi, group: entry
    -# NOTE: title belongs to InvoiceRun (f), not Invoice (fi). The InvoiceRun's title is copied to each generated Invoice.
    = f.labeled_input_field :title, help: t('.recipient_info', count: entry.recipients(current_user).count), data: { message_template_target: :title }
    = fi.labeled_input_field :description, rows: 3, data: { message_template_target: :body }
    = fi.labeled_input_field :payment_information
    = fi.labeled_input_field :payment_purpose
    = fi.labeled_date_field :issued_at
    = render_extensions :form_invoice_fields, locals: { f: fi }
    = field_set_tag do
      = render "invoice_articles", f: fi, group: group

    = field_set_tag do
      = fi.labeled_inline_fields_for :invoice_items, 'invoice_items'

    = field_set_tag do
      = fi.labeled_input_field :hide_total

    = render "invoices/recalculate/calculated", invoice: fi.object.decorate
