= f.hidden_field(:template_id)

- # lookup if a partial for the question type and render it if it exists.
- # `lookup_context.find_all` needs the partial including the leading underscore,
- # while `render` requires you to pass the partial name without it.
= render "event/questions/derived_fields", f: f

= f.labeled_input_field(:required, caption: t('event.questions.required_caption'), disabled: f.object.admin?)

- if Settings.event.participations.manual_sensitive_option
  - delete_answers_after_months = Settings.event.participations.delete_answers_after_months
  = f.labeled_input_field(:sensitive, caption: t('event.questions.sensitive_caption', cutoff: delete_answers_after_months), disabled: true)

= render 'event/questions/visibility_fields', f: f

= render_extensions :fields, locals: { f: f }

.controls.align-with-form
  = link_to(ta(:remove), "javascript:void(0)", data: { action: "events--question-template-nested-form#remove" })

.controls.fields-separation
  %hr
