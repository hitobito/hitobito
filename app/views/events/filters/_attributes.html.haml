.filter_attribute_form_template.d-none
  = event_filter_attribute_control_template(filter.event_type)

.control_group{data: { types: event_filter_types_for_data_attribute(filter.event_type) } }
  #filter_attribute_forms
    = event_filter_attribute_controls(filter.event_type, filter.chain[:attributes])

  = select(:attribute,
           :filter,
           event_filter_attributes_for_select(filter.event_type),
           { include_blank: "" },
           { class: "form-select form-select-sm" })


