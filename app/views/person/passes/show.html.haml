- title entry.pass_definition.name

- content_for(:toolbar) do
  = action_button t('person.passes.index.download_pdf'), group_person_pass_path(*parents, entry, format: :pdf), "print"
  - if google_wallet_configured?
    = action_button t('person.passes.index.add_to_google_wallet'), google_wallet_group_person_pass_path(*parents, entry), "add"
  - if apple_wallet_configured?
    = action_button t('person.passes.index.add_to_apple_wallet'), group_person_pass_path(*parents, entry, format: :pkpass), "add"

= render pass_template_partial(entry.pass_definition.template.pass_view_partial, 'show')
