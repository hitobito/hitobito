#invoice-list-destroy.modal.fade
  .modal-dialog
    .modal-content
      .modal-header
        %h5.bold.modal-title
          %b= t('.title')

      = standard_form(path_args(entry),
        url: group_period_invoice_template_invoice_run_invoice_runs_destroy_path(entry.group, entry.period_invoice_template, entry),
        method: :delete) do |f|
        .modal-body
          .row-fluid
            = hidden_field_tag('id', entry.id)

            - if deletable?
              = t('.confirm_delete')
            - else
              - if @non_draft_invoice_present
                = t('.non_draft_info')

        .modal-footer
          = submit_button(f, ti('link.delete'), disabled: !deletable?)
          = link_to(ti('button.cancel'), '#',
            class: 'link cancel',
            onclick: "event.preventDefault(); $('#invoice-list-destroy').modal('hide')")
