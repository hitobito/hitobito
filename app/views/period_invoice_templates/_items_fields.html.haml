%template{ data: { nested_form_target: "template", nested_form_variant: item_class.demodulize.underscore } }
  = f.fields_for :items, item_class.constantize.new, child_index: 'NEW_RECORD' do |item_fields|
    = render "#{item_class.underscore}_fields", f: item_fields

= f.fields_for :items do |item_fields|
  = render "#{item_class.underscore}_fields", f: item_fields
