- active_groups, deleted_groups = groups_and_roles_that_see_me.partition { |_id, g| !g[:deleted] }

%table.table.table-striped
  %tbody
    - active_groups.each do |id, group|
      %tr
        %td
          %strong= link_to group[:name], group_path(id)
        %td
          %p= group[:roles].join(", ")

- if deleted_groups.any?
  %h3= t('.deleted_groups')
  %table.table.table-striped
    %tbody
      - deleted_groups.each do |id, group|
        %tr
          %td
            %strong= group[:name]
          %td
            %p= group[:roles].join(", ")
