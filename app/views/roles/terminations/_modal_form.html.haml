#role-termination.modal.fade
  .modal-dialog
    .modal-content
      .modal-header
        %h5.bold.modal-title
          %b= ti('title')

      = standard_form entry, url: group_role_terminations_path(role_id: role.id, group_id: role.group_id), remote: true do |form|
        .modal-body
          = render StepsComponent.new(partials: entry.partials, step: entry.current_step, form: form)
