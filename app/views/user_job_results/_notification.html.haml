%div.toast{"data-controller": "user-job-result-notification"}
  .toast-header.d-flex.justify-content-between{class: job_status_class_names(user_job_result)}
    %strong.text-light= t(".job_#{user_job_result.status}")
    %button.btn-close{"data-bs-dismiss" => "toast", :type => "button"}
  .toast-body
    = user_job_result.job_name
