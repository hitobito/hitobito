%div.row
  = render 'simple_radio',
           attr: 'range',
           value: 'deep',
           checked: true,
           caption: "events/filters.form.range.#{group.layer? ? 'deep' : 'group_deep'}"
  - if group.layer?
    = render 'simple_radio', attr: 'range', value: 'layer', checked: filter.range == 'layer'
  = render 'simple_radio', attr: 'range', value: 'group', checked: filter.range == 'group'

%br/
