%p
  = t("groups.statistics.people.description", subject: Person.model_name.human(count: 2), groups: statistic.group_names.join(', '))

%table.table.table-striped.table-hover.group-statistic
  - cols = %i[year age count]
  %thead
    %tr
      - cols.each do |col|
        %th= t("groups.statistics.#{col}")
      %th= t("groups.statistics.distribution")
  %tbody
    - statistic.age_groups.each do |age_group|
      %tr
        - cols.each do |col|
          %td= maybe_value(age_group.send(col))
        %td
          .progress
            .progress-bar{style: "width: #{distribution_bar_width(age_group.relative_count, statistic.max_relative_count)}"}
    %tr
      %td
        %strong= t('global.all')
      %td
      %td
        %strong= statistic.total_count
      %td
