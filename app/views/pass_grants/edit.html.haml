- title t('.title')

= entry_form(url: group_pass_definition_pass_grant_path(@group, @pass_definition, entry),
             cancel_url: group_pass_definition_path(@group, @pass_definition),
             noindent: true) do |f|

  = field_set_tag Group.model_name.human do
    = f.string_field(:grantor, readonly: true)

  = field_set_tag Role.model_name.human(count: 2) do
    #roles.label-columns= render 'roles', selected: entry.related_role_types.map(&:role_type)
