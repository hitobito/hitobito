- if @passes.present?
  %section.passes
    %h2
      = t('.title')

    %table.table.table-basic
      %tbody
        - @passes.each do |pass|
          %tr
            %td
              %strong
                = icon('id-card')
                = link_to pass.pass_definition.name, group_person_pass_path(@group, entry, pass)
            %td
              - if pass.valid_until.present?
                = Pass.human_attribute_name(:valid_until)
                = l(pass.valid_until)
