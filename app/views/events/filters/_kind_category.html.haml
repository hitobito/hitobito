= f.fields_for(:course_kind_category) do |fields|
  .row.mb-2
    = fields.label(:id, ti('.kind_category'), class: "col-form-label col-md-3 col-xl-2")
    .col-md-9.mw-63ch
      - categories = Event::KindCategory.list
      = fields.select(:id,
                      options_from_collection_for_select(categories, :id, :to_s, Array(filter.chain.dig(:course_kind_category, :id))),
                      {},
                      class: "form-select form-select-sm w-100",
                      multiple: true,
                      data: { chosen_no_results: t("global.chosen_no_results"),
                              controller: "tom-select" })
