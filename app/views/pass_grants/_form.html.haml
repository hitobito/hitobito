= entry_form(url: group_pass_definition_pass_grants_path(@group, @pass_definition), noindent: true) do |f|

  = field_set_tag Group.model_name.human do
    = f.string_field(:grantor,
                     placeholder: t('global.search.placeholder_group'),
                     data: {provide: 'entity',
                            id_field: 'pass_grant_grantor_id',
                            url: query_group_pass_definition_pass_grants_path(@group, @pass_definition)})

    = f.hidden_field(:grantor_id,
                     data: { remote: true,
                             url: roles_group_pass_definition_pass_grants_path(@group, @pass_definition)})
    = f.hidden_field(:grantor_type, value: 'Group')

  = field_set_tag Role.model_name.human(count: 2) do
    #roles.label-columns= render 'roles'
