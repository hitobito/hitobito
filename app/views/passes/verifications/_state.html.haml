- if @state == :valid
  .alert.alert-success
    %span.fas.fa-check
    = t('passes.verifications.status.valid')
- elsif @state == :expired
  .alert.alert-warning
    %span.fas.fa-times-circle
    = t('passes.verifications.status.expired')
- else
  .alert.alert-danger
    %span.fas.fa-times-circle
    = t('passes.verifications.status.invalid')
