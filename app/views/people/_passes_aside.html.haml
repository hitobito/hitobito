- passes = entry.passes.eligible.includes(:pass_definition)
- if passes.any?
  %section.passes
    %h2
      = t('.title')

    %table.table.table-basic
      %tbody
        - passes.each do |membership|
          %tr
            %td
              %strong
                = icon('id-card')
                = link_to group_person_pass_path(@group, entry, membership.pass_definition) do
                  = membership.pass_definition.name
            %td
              - if membership.valid_until.present?
                = t('activerecord.attributes.pass.valid_until')
                = l(membership.valid_until)
