- if @year
  .float-end
    = render 'shared/page_per_year', paging_params: { returning: true }

= crud_table do |t|
  - t.col(t.sort_header(:title)) do |item|
    = content_tag(:strong) do
      = link_to(item.title, group_period_invoice_template_invoice_run_path(group, period_invoice_template, item))

  - t.sortable_attrs(:recipients_total, :recipients_paid, :amount_total, :amount_paid)

  - t.col(nil) do |item|
    - if can?(:destroy, item)
      = link_to(icon(:'trash-alt', filled: false),
                group_period_invoice_template_invoice_run_invoice_runs_destroy_path(group_id: item.group_id, period_invoice_template_id: period_invoice_template.id, invoice_run_id: item.id),
                class: 'action', title: ti(:"link.delete"), alt: ti(:"link.delete"),
                data: { method: :get },
                remote: true)
