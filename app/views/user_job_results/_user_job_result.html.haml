.container-fluid.text-center.bg-light.m-2.p-3{id: dom_id(user_job_result)}
  .row
    .col-1
      = job_status_icon(user_job_result.status.to_sym)
    .col-3
      = user_job_result.name
    .col-3
      = job_progress_bar(user_job_result.progress)
    .col-3
      = "#{UserJobResult.human_attribute_name('start_timestamp')}: #{job_timestamp(user_job_result.start_timestamp)}"
      %br
      = "#{UserJobResult.human_attribute_name('end_timestamp')}: #{job_timestamp(user_job_result.end_timestamp)}"
    .col-1
      = "#{UserJobResult.human_attribute_name('attempts')}: #{user_job_result.attempts}/#{Delayed::Worker.max_attempts}"
    .col-1
      - if user_job_result.generated_file.attached?
        = link_to(icon("download", {filled: true}), "/user_job_results/#{user_job_result.id}/download_attachment")
