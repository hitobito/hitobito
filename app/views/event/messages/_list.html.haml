- title @event.to_s

.pagination-bar
  = paginate @messages

= crud_table do |t|
  - t.sortable_attr(:sent_at, class: "col-lg-2")
  - t.sortable_attr(:subject)
  - t.col(Message.human_attribute_name(:recipients)) do |message|
    = message.message_recipients.map { |r| r.person.to_s }.sort.join(", ")

= paginate @messages
