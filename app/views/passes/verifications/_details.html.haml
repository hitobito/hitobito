#details
  = render_extensions(:details_header)
  - if @person
    #member-img= image_tag(upload_url(@person, :picture))
    #member-name= @person.full_name
    = render_extensions(:below_name)
    = render "state"
    = render_extensions(:member_details)
  - else
    .alert.alert-danger
      %span.fas.fa-times-circle
      = t('passes.verifications.failed')
