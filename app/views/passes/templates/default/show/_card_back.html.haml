-# locals: (pass:)

.pass-card.pass-card-back{style: pass_card_style(pass)}
  .pass-card-back-content
    .pass-card-qr
      = pass_qr_code_svg(pass)
    - if pass.definition.description.present?
      %p.pass-card-back-description= pass.definition.description
    %p.pass-card-back-title= pass.definition.name
