- key = attr.gsub(/\W+/, '_').gsub(/_+$/, '')
- caption ||= "events/filters.form.#{key}.#{value}"
- help ||= "events/filters.form.#{key}.#{value}_help"

.form-check
  = radio_button_tag(attr, value, checked, class: "form-check-input")
  = label_tag("#{key}_#{value}", t(caption), class: 'form-check-label')
