- if filter.event_type.possible_states.present?
  = f.fields_for(:state) do |fields|
    .row.mb-2
      = fields.label(:states, ti('.states'), class: "col-form-label col-md-3 col-xl-2")
      .col-md-9.mw-63ch
        - states = EventDecorator.new(filter.event_type.new).state_collection
        = fields.select(:states,
                        options_from_collection_for_select(states, :id, :to_s, filter.chain.dig(:state, :states)),
                        {},
                        class: "form-select form-select-sm w-100",
                        multiple: true,
                        data: { chosen_no_results: t("global.chosen_no_results"),
                                controller: "tom-select" })
