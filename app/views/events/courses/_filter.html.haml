= form_for(:filters, { method: :get, data: { turbo_frame: :event_courses_list}, id: "course-filter" }) do |form|
  - selected_kind_category_id = @filter.chain.dig(:course_kind_category, :id)
  - if selected_kind_category_id.present?
    = form.fields_for('course_kind_category') do |f|
      = f.hidden_field :id, value: selected_kind_category_id

  .d-xl-inline-flex.gap-2
    = form.fields_for('date_range') do |f|
      .control-group.mt-1
        = f.label :since, t(".time_period"), class: "control-label"
        .input-group
          %span.input-group-text= icon(:"calendar-alt")
          = f.text_field(:since,
                       value: @filter.chain.dig(:date_range, :since),
                         class: "date col-2 form-control form-control-sm mb-0")

      .control-group.mt-1
        = f.label :until, t(".until"), class: "control-label"
        .input-group
          %span.input-group-text= icon(:"calendar-alt")
          = f.text_field(:until,
                         value: @filter.chain.dig(:date_range, :until),
                         class: "date col-2 form-control form-control-sm mb-0")

    .control-group.mt-1
      = form.fields_for('places_available') do |f|
        = f.label :value, Event::Application.model_name.human, class: "control-label"
        .input-group
          = f.select(:value,
                    [[t(".places_available.all"), 0], [t(".places_available.only_with_places_available"), 1]],
                    { selected: @filter.chain.dig(:places_available, :value) },
                    class: "mb-0 form-select form-select-sm h-100")

    - if course_states_used?
      .control-group.mt-1
        = form.fields_for('state') do |f|
          = f.label :states, Event::Course.human_attribute_name(:state), class: "control-label"
          .input-group
            = f.select(:states,
                      options_from_collection_for_select(course_state_collection, :second, :first, @filter.chain.dig(:state, :states)),
                      {},
                      { id: "state-filter-select",
                        class: "form-select form-select-sm w-100",
                        multiple: true,
                        data: { chosen_no_results: t("global.chosen_no_results"),
                                placeholder: t(".select_states"),
                                controller: "tom-select" } })

  = render partial: "group_filter", locals: { form: form }

  .control-group
    = submit_button(form, safe_join([icon(:search), " ", t("global.button.search")]), name: nil)
